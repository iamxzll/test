<view class="container">
  <view class="search-section">
    <view class="search-bar">
      <view class="search-icon">🔍</view>
      <input
        class="search-input"
        placeholder="{{searchMode === 'gear' ? '请输入装备名称' : '请输入材料名称'}}"
        value="{{keyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        focus="{{searchFocus}}"
        confirm-type="search"
      />
      <view wx:if="{{keyword}}" class="clear-btn" bindtap="onClearSearch">✕</view>
    </view>
  </view>

  <view class="tab-bar">
    <view
      class="tab-item {{searchMode === 'gear' ? 'active' : ''}}"
      bindtap="switchSearchMode"
      data-mode="gear"
    >
      按装备搜索
    </view>
    <view
      class="tab-item {{searchMode === 'material' ? 'active' : ''}}"
      bindtap="switchSearchMode"
      data-mode="material"
    >
      按材料搜索
    </view>
  </view>

  <view class="result-section">
    <view wx:if="{{loading}}" class="loading">
      <view class="loading-text">加载中...</view>
    </view>

    <view wx:elif="{{!keyword}}" class="empty-tip">
      <view class="empty-icon">📦</view>
      <view class="empty-text">请输入关键词开始搜索</view>
    </view>

    <view wx:elif="{{resultList.length === 0}}" class="empty-tip">
      <view class="empty-icon">🔍</view>
      <view class="empty-text">未找到相关{{searchMode === 'gear' ? '装备' : '材料'}}</view>
    </view>

    <view wx:else class="result-list">
      <view
        class="result-item"
        wx:for="{{resultList}}"
        wx:key="_id"
        bindtap="onItemTap"
        data-item="{{item}}"
      >
        <view class="item-header">
          <view class="item-name">{{item.name}}</view>
          <view wx:if="{{searchMode === 'material'}}" class="item-tag">包含该材料</view>
        </view>
        <view wx:if="{{item.description}}" class="item-desc">{{item.description}}</view>
        <view wx:if="{{item.materials && item.materials.length > 0}}" class="item-materials">
          <view class="materials-label">制作材料：</view>
          <view class="materials-list">
            <text
              class="material-tag {{item.materials[index] === matchedMaterial ? 'highlight' : ''}}"
              wx:for="{{item.materials}}"
              wx:for-item="mat"
              wx:for-index="index"
              wx:key="index"
            >
              {{mat}}
            </text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
