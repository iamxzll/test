.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}
 
.search-header {
  background-color: #fff;
  padding: 20rpx 30rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
 
.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
 
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}
 
.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}
 
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 48rpx;
  line-height: 48rpx;
}
 
.clear-btn {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #ccc;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  margin-left: 16rpx;
}
 
.search-btn {
  flex-shrink: 0;
  height: 72rpx;
  padding: 0 32rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}
 
.search-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}
 
.mode-switch-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
 

 
.mode-switch {
  position: relative;
  display: flex;
  align-items: center;
  background-color: #f0f0f0;
  border-radius: 32rpx;
  padding: 6rpx;
  flex: 1;
}
 
.switch-bg {
  position: absolute;
  left: 6rpx;
  width: calc(50% - 6rpx);
  height: 60rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 26rpx;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
  box-shadow: 0 2rpx 8rpx rgba(22, 119, 255, 0.25);
}
 
.switch-bg.right {
  transform: translateX(100%);
}
 
.switch-item {
  position: relative;
  z-index: 2;
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  color: #666;
  font-weight: 400;
  transition: color 0.3s ease, font-weight 0.3s ease;
}
 
.switch-item.active {
  color: #fff;
  font-weight: 500;
}
 
.tab-bar {
  display: flex;
  background-color: #fff;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eee;
}
 
.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}
 
.tab-item.active {
  color: #1677ff;
  font-weight: 500;
}
 
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1677ff;
  border-radius: 2rpx;
}
 
.result-section {
  padding: 20rpx;
}
 
.result-count {
  font-size: 26rpx;
  color: #999;
  padding: 10rpx 10rpx 20rpx;
}
 
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
 
.loading-text {
  font-size: 28rpx;
  color: #999;
}
 
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
 
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}
 
.empty-text {
  font-size: 28rpx;
  color: #999;
}
 
.result-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
 
.result-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}
 
.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
 
.item-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
}
 
.item-tag {
  font-size: 22rpx;
  color: #1677ff;
  background-color: #e6f0ff;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}
 
.item-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
 
.meta-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
 
.body-tag {
  background-color: #e6f4ff;
}
 
.body-tag .meta-label {
  color: #1677ff;
}
 
.body-tag .meta-value {
  color: #0958d9;
  font-weight: 500;
}
 
.type-tag {
  background-color: #f6ffed;
}
 
.type-tag .meta-label {
  color: #52c41a;
}
 
.type-tag .meta-value {
  color: #389e0d;
  font-weight: 500;
}
 
.meta-label {
  opacity: 0.7;
}
 
.meta-value {
  font-weight: 500;
}
 
.item-materials {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 12rpx;
}
 
.materials-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 8rpx;
}
 
.materials-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  flex: 1;
}
 
.material-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #666;
  background-color: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  line-height: 1.4;
}
 
.mat-name {
  color: #333;
}
 
.mat-count {
  color: #999;
  font-weight: 500;
}
 
.material-tag.highlight {
  background-color: #fff3e6;
}
 
.material-tag.highlight .mat-name {
  color: #ff6b00;
}
 
.material-tag.highlight .mat-count {
  color: #ff8c3a;
}
